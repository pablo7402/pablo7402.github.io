---
layout: base.njk
titre: Liste de souhaits — Kove 800X Pro
permalink: /wishlist/
bodyClass: page-wishlist
---
<section class="page-header">
  <h1 class="reveal">Liste de souhaits</h1>
  <p class="lead reveal delay-1">Équipements à tester, destinations rêvées, modifications envisagées.</p>
</section>

{% set groups = [
  { label: "Équipement à tester", items: collections.wishlistEquipement },
  { label: "Destinations rêvées (TET)", items: collections.wishlistDestinations },
  { label: "Modifications mécaniques", items: collections.wishlistModifications }
] %}

<section class="wishlist-page">
  {% for group in groups %}
  <div class="wishlist-category reveal">
    <div class="category-header">
      <h2>{{ group.label }}</h2>
      {% if group.items.length %}
      <span class="category-meta">{{ group.items.length }} envie{{ "s" if group.items.length > 1 }} &middot; {{ group.items | sumBy("prix") | formatPrice }} &euro;</span>
      {% endif %}
    </div>

    {% if group.items.length %}
    <div class="wishlist-cards-grid">
      {% for item in group.items %}
      <article class="wishlist-card">
        <div class="wishlist-card-image">
          <img src="{{ item.data.image or '/images/voyage-placeholder.jpg' }}" alt="{{ item.data.titre }}" loading="lazy">
        </div>
        <div class="wishlist-card-body">
          <h3>{{ item.data.titre }}</h3>
          {% if item.data.detail %}<p class="wishlist-card-detail">{{ item.data.detail }}</p>{% endif %}
          <div class="wishlist-card-price-row">
            {% if item.data.prix %}<span class="wishlist-price">{{ item.data.prix | formatPrice }} &euro;</span>{% endif %}
            {% if item.data.lien %}<a class="wishlist-domain" href="{{ item.data.lien }}" target="_blank" rel="noopener">{{ item.data.lien | hostname }} ↗</a>{% endif %}
          </div>
          {% if item.data.lien %}
          <a class="btn-select" href="{{ item.data.lien }}" target="_blank" rel="noopener">Sélectionner</a>
          {% else %}
          <span class="btn-select btn-select-disabled">Sélectionner</span>
          {% endif %}
        </div>
      </article>
      {% endfor %}
    </div>
    {% else %}
    <p class="empty-state">Rien pour l'instant.</p>
    {% endif %}
  </div>
  {% endfor %}
</section>

<p class="page-footnote reveal">Pour ajouter ou modifier un élément, rends-toi dans le <a href="/admin/">mode éditeur</a>.</p>

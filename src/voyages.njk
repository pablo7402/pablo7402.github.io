---
layout: base.njk
titre: Voyages
permalink: /voyages/
bodyClass: page-voyages
---
<section class="page-header">
  <h1 class="reveal">Voyages</h1>
  <p class="lead reveal delay-1">Chaque étape, en un coup d'œil. Clique pour lire le récit complet.</p>
</section>

<section class="cards-grid journeys-grid">
  {% for voyage in collections.voyages %}
  {% set tags = voyage.data.tags | validTags %}
  <a class="card journey-card reveal" href="{{ voyage.url }}">
    <div class="card-image">
      <img src="{{ voyage.data.image or '/images/voyage-placeholder.jpg' }}" alt="{{ voyage.data.titre or 'Voyage' }}" loading="lazy">
    </div>
    <div class="card-body">
      {% set metaLine = { region: voyage.data.region, date: voyage.data.date } | journeyMeta %}
      {% if metaLine %}<span class="card-eyebrow">{{ metaLine | safe }}</span>{% endif %}
      <h3>{{ voyage.data.titre or "Étape sans titre" }}</h3>
      {% if voyage.data.resume %}<p class="card-excerpt">{{ voyage.data.resume }}</p>{% endif %}
      {% if tags.length %}
      <div class="tag-row">
        {% for tag in tags %}<span class="tag-pill">{{ tag }}</span>{% endfor %}
      </div>
      {% endif %}
    </div>
  </a>
  {% else %}
  <p class="empty-state">Aucun voyage enregistré. Va dans le mode éditeur (<a href="/admin/">/admin</a>) pour ajouter ton premier trip.</p>
  {% endfor %}
</section>

---
layout: base.njk
titre: Voyages — Kove 800X Pro
permalink: /voyages/
bodyClass: page-voyages
---
<section class="page-header">
  <h1 class="reveal">Voyages</h1>
  <p class="lead reveal delay-1">Le carnet de bord, étape par étape.</p>
</section>

<section class="journeys">
  {% for voyage in collections.voyages %}
  <article class="journey reveal" id="{{ (voyage.data.titre or voyage.data.region or 'etape-' + loop.index) | slugify }}">
    {% if voyage.data.image %}
    <div class="journey-media">
      <img src="{{ voyage.data.image }}" alt="{{ voyage.data.titre or 'Photo de voyage' }}" loading="lazy">
    </div>
    {% endif %}

    <div class="journey-info">
      {% set metaLine = voyage.data | journeyMeta %}
      {% if metaLine %}
      <span class="card-eyebrow">{{ metaLine | safe }}</span>
      {% endif %}

      {% if voyage.data.titre %}<h2>{{ voyage.data.titre }}</h2>{% endif %}
      {% if voyage.data.resume %}<p class="journey-resume">{{ voyage.data.resume }}</p>{% endif %}

      {% if voyage.templateContent %}
      <div class="journey-recit">{{ voyage.templateContent | safe }}</div>
      {% endif %}

      {% set photos = voyage.data.photos | validPhotos %}
      {% if photos.length %}
      <div class="journey-gallery">
        {% for photo in photos %}
        <div class="journey-gallery-item">
          <img src="{{ photo.src }}" alt="{{ voyage.data.titre or 'Photo de voyage' }}" loading="lazy">
        </div>
        {% endfor %}
      </div>
      {% endif %}

      {% set videos = voyage.data.videos | validVideos %}
      {% if videos.length %}
      <div class="journey-videos">
        {% for video in videos %}
        {% set vid = video.url | youtubeId %}
        {% if vid %}
        <div class="video-embed">
          <iframe src="https://www.youtube-nocookie.com/embed/{{ vid }}" title="Vidéo du voyage" loading="lazy" allowfullscreen referrerpolicy="strict-origin-when-cross-origin"></iframe>
        </div>
        {% endif %}
        {% endfor %}
      </div>
      {% endif %}
    </div>
  </article>
  {% else %}
  <p class="empty-state">Aucun voyage enregistré. Va dans le mode éditeur (<a href="/admin/">/admin</a>) pour ajouter ton premier trip.</p>
  {% endfor %}
</section>

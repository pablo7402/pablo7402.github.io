---
layout: base.njk
titre: Kove 800X Pro — Accueil
bodyClass: page-home
---
<section class="hero">
  <img class="hero-media reveal-img" src="{{ site.heroImage }}" alt="Kove 800X Pro dans un paysage de montagne">
  <div class="hero-overlay"></div>
  <div class="hero-copy">
    <h1 class="reveal">{{ site.sousTitre }}</h1>
    <p class="reveal delay-1">{{ site.heroTexte }}</p>
    <a class="btn" href="/voyages/">Voir les voyages</a>
  </div>
  <div class="scroll-hint reveal delay-2">↓</div>
</section>

<section class="section-intro">
  <h2 class="reveal">Derniers trips</h2>
  <p class="lead reveal delay-1">Quelques étapes récentes, en un coup d'œil.</p>
</section>

<section class="cards-grid">
  {% for voyage in collections.voyages | limit(3) %}
  <a class="card reveal" href="/voyages/#{{ voyage.data.titre | slugify }}">
    <div class="card-image">
      <img src="{{ voyage.data.image or '/images/voyage-placeholder.jpg' }}" alt="{{ voyage.data.titre }}" loading="lazy">
    </div>
    <div class="card-body">
      <span class="card-eyebrow">{{ voyage.data.region }}</span>
      <h3>{{ voyage.data.titre }}</h3>
      <p>{{ voyage.data.resume }}</p>
    </div>
  </a>
  {% else %}
  <p class="empty-state">Aucun voyage pour l'instant. Ajoute ton premier trip depuis le mode éditeur (/admin).</p>
  {% endfor %}
</section>

<section class="cta-band reveal">
  <h2>Une idée, un équipement, une destination en tête ?</h2>
  <a class="btn btn-secondary" href="/wishlist/">Voir la liste de souhaits</a>
</section>

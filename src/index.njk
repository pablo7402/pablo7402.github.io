---
layout: base.njk
bodyClass: page-home
---
<section class="hero">
  <img class="hero-media reveal-img" src="{{ site.heroImage }}" alt="Kove 800X Pro dans un paysage de montagne">
  <div class="hero-overlay"></div>
  <div class="hero-copy">
    <h1 class="reveal">{{ site.sousTitre }}</h1>
    <p class="reveal delay-1">{{ site.heroTexte }}</p>
    <a class="btn" href="/voyages/">{{ site.heroBouton }}</a>
  </div>
  <div class="scroll-hint reveal delay-2">↓</div>
</section>

<section class="section-intro">
  <h2 class="reveal">{{ site.sectionVoyagesTitre }}</h2>
  <p class="lead reveal delay-1">{{ site.sectionVoyagesTexte }}</p>
</section>

<section class="cards-grid">
  {% for voyage in collections.voyages | limit(3) %}
  <a class="card reveal" href="{{ voyage.url }}">
    <div class="card-image">
      <img src="{{ voyage.data.image or '/images/voyage-placeholder.jpg' }}" alt="{{ voyage.data.titre or 'Voyage' }}" loading="lazy">
    </div>
    <div class="card-body">
      {% if voyage.data.region %}<span class="card-eyebrow">{{ voyage.data.region }}</span>{% endif %}
      <h3>{{ voyage.data.titre or "Étape sans titre" }}</h3>
      {% if voyage.data.resume %}<p>{{ voyage.data.resume }}</p>{% endif %}
    </div>
  </a>
  {% else %}
  <p class="empty-state">Aucun voyage pour l'instant. Ajoute ton premier trip depuis le mode éditeur (/admin).</p>
  {% endfor %}
</section>

{% if site.apropos %}
<section class="about-section">
  <h2 class="reveal">À propos</h2>
  <p class="lead reveal delay-1">{{ site.apropos }}</p>
</section>
{% endif %}

<section class="cta-band reveal">
  <h2>{{ site.ctaTitre }}</h2>
  <a class="btn btn-secondary" href="/wishlist/">{{ site.ctaBouton }}</a>
</section>
